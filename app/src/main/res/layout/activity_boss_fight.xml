<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBoss"
        android:src="@drawable/boss_idle_1"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerInside"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvChance"
        android:text="Šansa: 0%"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/hpBar"
        style="@style/Widget.Material3.LinearProgressIndicator"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        app:indicatorColor="@android:color/holo_red_dark"
        app:trackColor="@android:color/darker_gray"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvHp"
        android:text="HP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/ppBar"
        style="@style/Widget.Material3.LinearProgressIndicator"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        app:indicatorColor="@android:color/holo_blue_light"
        app:trackColor="@android:color/darker_gray"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvPp"
        android:text="PP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- activity_battle.xml -->
    <LinearLayout
        android:id="@+id/rewardBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgCoin"
            android:layout_width="28dp"
            android:layout_height="28dp"
            app:srcCompat="@drawable/coin"/>

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="0"/>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageView
            android:id="@+id/imgGear"
            android:layout_width="28dp"
            android:layout_height="28dp"
            app:srcCompat="@drawable/gear_clothes"/>

        <TextView
            android:id="@+id/tvGear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="—"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layGear"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <!-- ikonice opreme (ImageView) – popuni dinamički -->
    </LinearLayout>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTries"
        android:text="Pokušaji: 5/5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAttack"
        android:text="NAPADNI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvHint"
        android:text="Protresi telefon za napad (shake)"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"/>
</LinearLayout>
